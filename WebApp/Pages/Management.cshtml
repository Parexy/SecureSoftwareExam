@page
@model WebApp.Pages.Admin.ManagementModel

@{
    ViewData["Title"] = "Management";
}

<h1>Management</h1>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        @Model.ErrorMessage
    </div>
}

<div class="mb-3">
    <a asp-page="/Management"
           asp-route-view="patients"
           class="btn @(Model.ActiveView == "patients" ? "btn-primary" : "btn-outline-primary")">
        Patients
    </a>

    @if (Model.IsAdmin)
    {
        <a asp-page="/Management"
               asp-route-view="staff"
               class="btn @(Model.ActiveView == "staff" ? "btn-primary" : "btn-outline-primary")">
            Staff members
        </a>
    }
</div>

@if (Model.ActiveView == "staff" && Model.IsAdmin)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Staff members</h2>

        <a asp-page="/StaffMembers/Create" class="btn btn-success">
            Create staff member
        </a>
    </div>

    @if (!Model.StaffMembers.Any())
    {
        <div class="alert alert-info">
            No staff members found.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Date of birth</th>
                    <th>Role</th>
                    <th style="width: 320px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var staffMember in Model.StaffMembers)
                {
                    <tr>
                        <td>@staffMember.Name</td>
                        <td>@staffMember.Email</td>
                        <td>@staffMember.PhoneNumber</td>
                        <td>@staffMember.DateOfBirth.ToString("yyyy-MM-dd")</td>
                        <td>@staffMember.Role</td>
                        <td>
                            <a asp-page="/StaffMembers/Edit"
                                   asp-route-id="@staffMember.Id"
                                   class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>

                            <a asp-page="/StaffMembers/ResetPassword"
                                   asp-route-id="@staffMember.Id"
                                   class="btn btn-sm btn-outline-warning">
                                Reset password
                            </a>

                            <a asp-page="/StaffMembers/Delete"
                                   asp-route-id="@staffMember.Id"
                                   class="btn btn-sm btn-outline-danger">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Patients</h2>

        <a asp-page="/Patients/Create" class="btn btn-success">
            Create patient
        </a>
    </div>

    @if (!Model.Patients.Any())
    {
        <div class="alert alert-info">
            No patients found.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>CPR</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Date of birth</th>
                    <th>Gender</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var patient in Model.Patients)
                {
                    <tr>
                        <td>@patient.CPRNumber</td>
                        <td>@patient.Name</td>
                        <td>@patient.Email</td>
                        <td>@patient.PhoneNumber</td>
                        <td>@patient.DateOfBirth.ToString("yyyy-MM-dd")</td>
                        <td>@patient.Gender</td>
                        <td>
                            <a asp-page="/Patients/Edit"
                                   asp-route-id="@patient.Id"
                                   class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>

                            @if (Model.IsAdmin)
                            {
                                <a asp-page="/Patients/Delete"
                                       asp-route-id="@patient.Id"
                                       class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}