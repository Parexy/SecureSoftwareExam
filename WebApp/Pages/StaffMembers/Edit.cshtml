@page "{id:int}"
@model WebApp.Pages.StaffMembers.EditModel

@{
    ViewData["Title"] = "Edit staff member";
}

<h1>Edit staff member</h1>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        @Model.ErrorMessage
    </div>
}

<form method="post" class="mt-3">
    <div class="mb-3">
        <label asp-for="StaffMember.Username" class="form-label"></label>
        <input asp-for="StaffMember.Username" class="form-control" />
        <div class="form-text">
            If username editing is not supported by your API yet, leave this empty or remove this field.
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="StaffMember.Name" class="form-label"></label>
        <input asp-for="StaffMember.Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="StaffMember.Address" class="form-label"></label>
        <input asp-for="StaffMember.Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="StaffMember.PhoneNumber" class="form-label"></label>
        <input asp-for="StaffMember.PhoneNumber" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="StaffMember.Email" class="form-label"></label>
        <input asp-for="StaffMember.Email" type="email" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="StaffMember.DateOfBirth" class="form-label"></label>
        <input asp-for="StaffMember.DateOfBirth" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="StaffMember.Role" class="form-label"></label>
        <select asp-for="StaffMember.Role" class="form-select">
            <option value="">Select role</option>
            <option value="Admin">Admin</option>
            <option value="Doctor">Doctor</option>
            <option value="Nurse">Nurse</option>
            <option value="Receptionist">Receptionist</option>
        </select>
    </div>

    <div class="form-check mb-3">
        <input asp-for="StaffMember.Enabled" class="form-check-input" />
        <label asp-for="StaffMember.Enabled" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">
        Save
    </button>

    <a asp-page="/Admin/Management" asp-route-view="staff" class="btn btn-secondary">
        Cancel
    </a>
</form>