@page
@model WebApp.Pages.ProfileModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-5">

    <h2>My Profile</h2>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            @Model.ErrorMessage
        </div>
    }
    else if (Model.Patient == null)
    {
        <div class="alert alert-info">
            Loading failed or no profile found.
        </div>
    }
    else
    {
        <div class="card mt-3">
            <div class="card-body">

                <p><strong>Name:</strong> @Model.Patient.Name</p>
                <p><strong>CPR:</strong> @Model.Patient.CPRNumber</p>
                <p><strong>Email:</strong> @Model.Patient.Email</p>
                <p><strong>Phone:</strong> @Model.Patient.PhoneNumber</p>
                <p><strong>Address:</strong> @Model.Patient.Address</p>
                <p><strong>Date of Birth:</strong> @Model.Patient.DateOfBirth.ToString("yyyy-MM-dd")</p>
                <p><strong>Gender:</strong> @Model.Patient.Gender</p>

            </div>
        </div>
    }

</div>