@page
@model WebApp.Pages.Patients.CreateModel

@{
    ViewData["Title"] = "Create patient";
}

<h1>Create patient</h1>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        @Model.ErrorMessage
    </div>
}

<form method="post" class="mt-3">
    <div class="mb-3">
        <label asp-for="Patient.CPRNumber" class="form-label"></label>
        <input asp-for="Patient.CPRNumber" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Patient.Name" class="form-label"></label>
        <input asp-for="Patient.Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Patient.Address" class="form-label"></label>
        <input asp-for="Patient.Address" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Patient.PhoneNumber" class="form-label"></label>
        <input asp-for="Patient.PhoneNumber" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Patient.Email" class="form-label"></label>
        <input asp-for="Patient.Email" type="email" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Patient.DateOfBirth" class="form-label"></label>
        <input asp-for="Patient.DateOfBirth" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Patient.Gender" class="form-label"></label>
        <input asp-for="Patient.Gender" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Patient.ExternalUserId" class="form-label"></label>
        <input asp-for="Patient.ExternalUserId" class="form-control" />
        <div class="form-text">
            Keycloak user ID. Leave empty if the patient does not have a login user yet.
        </div>
    </div>

    <button type="submit" class="btn btn-primary">
        Create
    </button>

    <a asp-page="/Admin/Management" asp-route-view="patients" class="btn btn-secondary">
        Cancel
    </a>
</form>